name: CI

# Runs only on push to main (as agreed).
on:
  push:
    branches: [main]
    paths:
      - 'app/**'
      - 'alembic/**'
      - 'Dockerfile'
      - 'pyproject.toml'
      - 'uv.lock'

# GITHUB_TOKEN permissions: read for code, write to publish the image to ghcr.io.
# Without packages: write the push to ghcr fails with 403.
permissions:
  contents: read
  packages: write

env:
  REGISTRY: ghcr.io
  IMAGE_NAME: ${{ github.repository }}   # niktedi/generic-app

jobs:
  # ──────────────────────────────────────────────────────────────
  # JOB 1: tests. Spins up Postgres as a service container, applies
  # Alembic migrations, runs ruff + pytest against the real database.
  # ──────────────────────────────────────────────────────────────
  test:
    runs-on: ubuntu-latest

    # Service container: GitHub spins up Postgres next to the runner.
    # Tests reach it over localhost:5432.
    services:
      postgres:
        image: postgres:16
        env:
          POSTGRES_USER: postgres
          POSTGRES_PASSWORD: postgres
          POSTGRES_DB: calendar_test
        ports:
          - 5432:5432
        # healthcheck: the job waits until Postgres is actually ready to
        # accept connections before running any steps.
        options: >-
          --health-cmd "pg_isready -U postgres"
          --health-interval 10s
          --health-timeout 5s
          --health-retries 5

    # These variables are read by both the app (app/config.py) and
    # alembic/env.py. The names must match exactly what the code expects.
    env:
      DB_HOST: localhost
      DB_PORT: "5432"
      DB_NAME: calendar_test
      DB_USER: postgres
      DB_PASSWORD: postgres

    steps:
      - name: Checkout
        uses: actions/checkout@v6

      - name: Install uv
        uses: astral-sh/setup-uv@v8.1.0
        with:
          enable-cache: true

      - name: Set up Python and sync deps
        run: uv sync --locked --dev

      - name: Lint (ruff)
        run: uv run ruff check .

      - name: Apply database migrations
        run: uv run alembic upgrade head

      - name: Run tests
        run: uv run pytest

  # ──────────────────────────────────────────────────────────────
  # JOB 2: build and publish the image. Runs ONLY if test passed
  # (needs: test). Tag is the short git SHA of the commit.
  # ──────────────────────────────────────────────────────────────
  build-push:
    runs-on: ubuntu-latest
    needs: test

    # id-token: write is REQUIRED for OIDC auth to AWS.
    # packages: write stays for the GHCR push. contents: read for checkout.
    permissions:
      contents: read
      packages: write
      id-token: write

    steps:
      - name: Checkout
        uses: actions/checkout@v6

      - name: Set up Docker Buildx
        uses: docker/setup-buildx-action@v4

      # ---- GHCR auth (existing, for homelab) ----
      - name: Log in to GitHub Container Registry
        uses: docker/login-action@v4
        with:
          registry: ghcr.io
          username: ${{ github.actor }}
          password: ${{ secrets.GITHUB_TOKEN }}

      # ---- AWS auth via OIDC (new, for ECR) ----
      - name: Configure AWS credentials (OIDC)
        uses: aws-actions/configure-aws-credentials@v4
        with:
          role-to-assume: arn:aws:iam::802421411869:role/github-actions-ecr-push
          aws-region: eu-central-1

      - name: Log in to Amazon ECR
        id: ecr-login
        uses: aws-actions/amazon-ecr-login@v2

      # ---- tags for BOTH registries ----
      - name: Extract image metadata (tags)
        id: meta
        uses: docker/metadata-action@v5
        with:
          images: |
            ghcr.io/${{ github.repository }}
            ${{ steps.ecr-login.outputs.registry }}/generic-app
          tags: |
            type=sha,prefix=

      - name: Build and push (GHCR + ECR)
        uses: docker/build-push-action@v7
        with:
          context: .
          push: true
          tags: ${{ steps.meta.outputs.tags }}
          labels: ${{ steps.meta.outputs.labels }}
          cache-from: type=gha
          cache-to: type=gha,mode=max
  
  # ──────────────────────────────────────────────────────────────
  # JOB 3: bump the image tag in both kustomizations and commit back.
  # Runs only if build-push succeeded. The paths filter above means
  # this bot commit (touching only kustomization.yaml) will NOT
  # re-trigger the workflow — no loop.
  # ──────────────────────────────────────────────────────────────
  bump-tags:
    runs-on: ubuntu-latest
    needs: build-push

    # contents: write is required to commit the tag bump back to the repo.
    permissions:
      contents: write

    steps:
      - name: Checkout
        uses: actions/checkout@v6

      - name: Install kustomize
        run: |
          curl -s "https://raw.githubusercontent.com/kubernetes-sigs/kustomize/master/hack/install_kustomize.sh" | bash
          sudo mv kustomize /usr/local/bin/

      - name: Bump image tags
        run: |
          SHA=$(echo "${{ github.sha }}" | cut -c1-7)

          cd kuber/base
          kustomize edit set image ghcr.io/niktedi/generic-app=ghcr.io/niktedi/generic-app:$SHA
          cd "$GITHUB_WORKSPACE"

          cd aws_eks/kuber
          kustomize edit set image 802421411869.dkr.ecr.eu-central-1.amazonaws.com/generic-app=802421411869.dkr.ecr.eu-central-1.amazonaws.com/generic-app:$SHA
          cd "$GITHUB_WORKSPACE"

      - name: Commit and push
        run: |
          SHA=$(echo "${{ github.sha }}" | cut -c1-7)
          git config user.name "github-actions[bot]"
          git config user.email "github-actions[bot]@users.noreply.github.com"
          git add kuber/base/kustomization.yaml aws_eks/kuber/kustomization.yaml
          if git diff --cached --quiet; then
            echo "No tag change, skipping commit."
          else
            git commit -m "ci: bump image to $SHA"
            git push
          fi
          